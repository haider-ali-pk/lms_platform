// prisma/schema.prisma
// EduFlow LMS — Full Schema v1.0
// Multi-tenant SaaS · Pakistan · 21,011 users · 10 schools

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  super_admin
  admin
  teacher
  student
  parent
}

enum PlanTier {
  starter
  growth
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
}

enum LessonType {
  video
  text
  pdf
  quiz
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum AssignmentStatus {
  submitted
  graded
  late
  missing
}

enum NotificationType {
  assignment_due
  quiz_result
  attendance_alert
  certificate_earned
  payment_alert
  general
}

enum CertificateStatus {
  issued
  revoked
}

// ─────────────────────────────────────────────
// CORE TABLES
// ─────────────────────────────────────────────

model School {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  email         String
  phone         String?
  address       String?
  city          String?
  logo_url      String?
  custom_domain String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  users               User[]
  courses             Course[]
  classes             Class[]
  stripe_subscription StripeSubscription?
  audit_logs          AuditLog[]
  notifications       Notification[]
enrollment_requests EnrollmentRequest[]
  @@index([slug])
  @@map("schools")
}

model User {
  id             String    @id @default(cuid())
  school_id      String?
  email          String    @unique
  password_hash  String
  role           Role
  first_name     String
  last_name      String
  phone          String?
  avatar_url     String?
  is_active      Boolean   @default(true)
  is_verified    Boolean   @default(false)
  two_fa_secret  String?
  two_fa_enabled Boolean   @default(false)
  otp_code       String?
  otp_expires_at DateTime?
  last_login_at  DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?
  ai_chat_sessions AiChatSession[]

  school                School?               @relation(fields: [school_id], references: [id])
  courses_created       Course[]              @relation("CourseAuthor")
  enrollments           Enrollment[]
  lesson_progress       LessonProgress[]
  quiz_attempts         QuizAttempt[]
  assignments_submitted AssignmentSubmission[]
  attendance_records    Attendance[]
 certificates          Certificate[]  @relation("StudentCertificates")
certificates_issued   Certificate[]  @relation("IssuedCertificates")
  ai_chat_history       AiChatHistory[]
  messages_sent         Message[]             @relation("Sender")
  messages_received     Message[]             @relation("Receiver")
  notifications         Notification[]
  audit_logs            AuditLog[]
  children              ParentStudent[]       @relation("ParentRelation")
  parents               ParentStudent[]       @relation("StudentRelation")
  classes_teaching      ClassTeacher[]

  @@index([school_id])
  @@index([email])
  @@index([role])
  @@index([deleted_at])
  @@map("users")
}

// ─────────────────────────────────────────────
// LEARNING TABLES
// ─────────────────────────────────────────────

model Course {
  id            String    @id @default(cuid())
  school_id     String
  author_id     String
  title         String
  description   String?
  thumbnail_url String?
  subject       String?
  grade_level   String?
  is_published  Boolean   @default(false)
  pass_mark     Int       @default(60)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  school      School       @relation(fields: [school_id], references: [id])
  author      User         @relation("CourseAuthor", fields: [author_id], references: [id])
  lessons     Lesson[]
  quizzes     Quiz[]
  assignments Assignment[]
  enrollments Enrollment[]
  certificates Certificate[]

  @@index([school_id])
  @@index([author_id])
  @@map("courses")
}

model Lesson {
  id           String     @id @default(cuid())
  course_id    String
  title        String
  content      String?
  video_url    String?
  pdf_url      String?
  type         LessonType @default(video)
  order        Int        @default(0)
  duration_min Int?
  is_published Boolean    @default(false)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  course   Course           @relation(fields: [course_id], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([course_id])
  @@index([order])
  @@map("lessons")
}

model Enrollment {
  id           String    @id @default(cuid())
  student_id   String
  course_id    String
  enrolled_at  DateTime  @default(now())
  completed_at DateTime?

  student User   @relation(fields: [student_id], references: [id])
  course  Course @relation(fields: [course_id], references: [id])

  @@unique([student_id, course_id])
  @@index([student_id])
  @@index([course_id])
  @@map("enrollments")
}

model LessonProgress {
  id           String    @id @default(cuid())
  student_id   String
  lesson_id    String
  is_completed Boolean   @default(false)
  watch_time   Int?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  student User   @relation(fields: [student_id], references: [id])
  lesson  Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([student_id, lesson_id])
  @@index([student_id])
  @@map("lesson_progress")
}

// ─────────────────────────────────────────────
// QUIZ ENGINE
// ─────────────────────────────────────────────

model Quiz {
  id           String   @id @default(cuid())
  course_id    String
  title        String
  description  String?
  time_limit   Int?
  pass_mark    Int      @default(60)
  max_attempts Int      @default(3)
  is_published Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  course    Course         @relation(fields: [course_id], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([course_id])
  @@map("quizzes")
}

model QuizQuestion {
  id            String @id @default(cuid())
  quiz_id       String
  question_text String
  options       Json
  correct_index Int
  explanation   String?
  points        Int    @default(1)
  order         Int    @default(0)

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id])
  @@map("quiz_questions")
}

model QuizAttempt {
  id           String   @id @default(cuid())
  quiz_id      String
  student_id   String
  answers      Json
  score        Int
  passed       Boolean
  time_taken   Int?
  submitted_at DateTime @default(now())

  quiz    Quiz @relation(fields: [quiz_id], references: [id])
  student User @relation(fields: [student_id], references: [id])

  @@index([quiz_id])
  @@index([student_id])
  @@map("quiz_attempts")
}

// ─────────────────────────────────────────────
// ASSIGNMENTS
// ─────────────────────────────────────────────

model Assignment {
  id           String   @id @default(cuid())
  course_id    String
  title        String
  description  String
  due_date     DateTime
  max_marks    Int      @default(100)
  is_published Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  course      Course                 @relation(fields: [course_id], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([course_id])
  @@map("assignments")
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignment_id String
  student_id    String
  file_url      String?
  text_answer   String?
  status        AssignmentStatus @default(submitted)
  marks         Int?
  feedback      String?
  submitted_at  DateTime         @default(now())
  graded_at     DateTime?

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [student_id], references: [id])

  @@unique([assignment_id, student_id])
  @@index([assignment_id])
  @@index([student_id])
  @@map("assignment_submissions")
}

// ─────────────────────────────────────────────
// SCHOOL OPERATIONS
// ─────────────────────────────────────────────

model Class {
  id            String   @id @default(cuid())
  school_id     String
  name          String
  grade         String?
  section       String?
  academic_year String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  school     School         @relation(fields: [school_id], references: [id])
  teachers   ClassTeacher[]
  attendance Attendance[]

  @@index([school_id])
  @@map("classes")
}

model ClassTeacher {
  id         String @id @default(cuid())
  class_id   String
  teacher_id String

  class   Class @relation(fields: [class_id], references: [id], onDelete: Cascade)
  teacher User  @relation(fields: [teacher_id], references: [id])

  @@unique([class_id, teacher_id])
  @@map("class_teachers")
}

model Attendance {
  id         String           @id @default(cuid())
  class_id   String
  student_id String
  date       DateTime         @db.Date
  status     AttendanceStatus @default(present)
  note       String?
  created_at DateTime         @default(now())

  class   Class @relation(fields: [class_id], references: [id])
  student User  @relation(fields: [student_id], references: [id])

  @@unique([class_id, student_id, date])
  @@index([class_id])
  @@index([student_id])
  @@index([date])
  @@map("attendance")
}

model ParentStudent {
  id         String @id @default(cuid())
  parent_id  String
  student_id String

  parent  User @relation("ParentRelation", fields: [parent_id], references: [id])
  student User @relation("StudentRelation", fields: [student_id], references: [id])

  @@unique([parent_id, student_id])
  @@map("parent_students")
}

model Certificate {
  id         String            @id @default(cuid())
  student_id String
  course_id  String
  issuer_id  String?
  grade      String?
  status     CertificateStatus @default(issued)
  pdf_url    String?
  score      Int               @default(0)
  issued_at  DateTime          @default(now())

  student User   @relation("StudentCertificates", fields: [student_id], references: [id])
  course  Course @relation(fields: [course_id], references: [id])
  issuer  User?  @relation("IssuedCertificates", fields: [issuer_id], references: [id])

  @@unique([student_id, course_id])
  @@index([student_id])
  @@map("certificates")
}

// ─────────────────────────────────────────────
// BUSINESS / BILLING
// ─────────────────────────────────────────────

model StripeSubscription {
  id                     String             @id @default(cuid())
  school_id              String             @unique
  stripe_customer_id     String             @unique
  stripe_subscription_id String             @unique
  plan                   PlanTier
  status                 SubscriptionStatus @default(trialing)
  current_period_start   DateTime
  current_period_end     DateTime
  cancel_at_period_end   Boolean            @default(false)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  school School @relation(fields: [school_id], references: [id])

  @@map("stripe_subscriptions")
}

// ─────────────────────────────────────────────
// AI & COMMUNICATION
// ─────────────────────────────────────────────

model AiChatHistory {
  id         String   @id @default(cuid())
  student_id String
  role       String
  content    String
  created_at DateTime @default(now())

  student User @relation(fields: [student_id], references: [id])

  @@index([student_id])
  @@index([created_at])
  @@map("ai_chat_history")
}

model Message {
  id          String    @id @default(cuid())
  sender_id   String
  receiver_id String
  content     String
  is_read     Boolean   @default(false)
  sent_at     DateTime  @default(now())
  read_at     DateTime?

  sender   User @relation("Sender", fields: [sender_id], references: [id])
  receiver User @relation("Receiver", fields: [receiver_id], references: [id])

  @@index([sender_id])
  @@index([receiver_id])
  @@map("messages")
}

model Notification {
  id         String           @id @default(cuid())
  user_id    String?
  school_id  String?
  scope      String           @default("user")  // "all" | "school:{id}" | "user"
  type       NotificationType
  title      String
  body       String
  is_read    Boolean          @default(false)
  meta       Json?
  created_at DateTime         @default(now())

  user   User?   @relation(fields: [user_id], references: [id])
  school School? @relation(fields: [school_id], references: [id])

  @@index([user_id])
  @@index([scope])
  @@index([is_read])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// SECURITY / AUDIT
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  user_id    String?
  school_id  String?
  action     String
  entity     String?
  entity_id  String?
  meta       Json?
  ip         String?
  user_agent String?
  created_at DateTime @default(now())

  user   User?   @relation(fields: [user_id], references: [id])
  school School? @relation(fields: [school_id], references: [id])

  @@index([user_id])
  @@index([school_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}
enum EnrollmentRequestStatus {
  pending
  approved
  rejected
}

model EnrollmentRequest {
  id           String                  @id @default(cuid())
  school_id    String
  student_name String
  parent_name  String
  phone        String
  grade        String
  date_of_birth DateTime              @db.Date
  status       EnrollmentRequestStatus @default(pending)
  notes        String?
  created_at   DateTime               @default(now())
  updated_at   DateTime               @updatedAt

  school School @relation(fields: [school_id], references: [id])

  @@index([school_id])
  @@index([status])
  @@map("enrollment_requests")
}
model AiChatSession {
  id         String   @id @default(cuid())
  user_id    String
  title      String
  subject    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages AiChatMessage[]

  @@index([user_id])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id         String   @id @default(cuid())
  session_id String
  role       String   // "user" | "assistant"
  content    String
  created_at DateTime @default(now())

  session AiChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("ai_chat_messages")
}